PORT=4000
JWT_SECRET=replace-with-a-secure-secret
## Example local MongoDB (recommended for development)
# MONGODB_URI=mongodb://localhost:27017/mern

## Example Atlas connection (replace <user>, <pass>, <cluster> and <dbname>)
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mern?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mern
MONGODB_DB=mern
CORS_ORIGIN=*