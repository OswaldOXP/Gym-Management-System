# Frontend (Vite)
# Leave empty for local dev proxy in vite.config.js
VITE_API_BASE_URL=

# Backend (also read by server/index.js when root .env is used)
PORT=4000
JWT_SECRET=replace-with-a-secure-secret
MONGODB_URI=mongodb://127.0.0.1:27017/ironcore
# Comma-separated allowed origins in production. Use * only for local dev.
CORS_ORIGIN=*
